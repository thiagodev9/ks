        {activeTab === 'pistoes' && (
          <div className="space-y-6 animate-in fade-in duration-500">
            <header className="flex justify-between items-end">
              <div>
                <h2 className="text-2xl font-bold text-white">Gestão de Pistões</h2>
                <p className="text-slate-400">Base de dados mestre de componentes</p>
              </div>
              <button className="bg-[#004a87] hover:bg-[#003a6b] text-white px-4 py-2 rounded-lg flex items-center space-x-2 transition-colors">
                <PlusCircle size={18} />
                <span>Novo Cadastro</span>
              </button>
            </header>

            <div className="bg-[#1e293b] rounded-xl border border-slate-700 overflow-hidden shadow-xl">
              <div className="p-4 border-b border-slate-700 bg-slate-800/50 flex items-center">
                <Search className="text-slate-500 mr-2" size={18} />
                <input placeholder="Procurar por descrição, ID ou chapa..." className="bg-transparent border-none outline-none text-slate-300 w-full text-sm" />
              </div>
              <table className="w-full text-left">
                <thead className="bg-slate-800/30 text-slate-400 text-xs uppercase tracking-wider">
                  <tr>
                    <th className="px-6 py-4 font-semibold">Descrição do Componente</th>
                    <th className="px-6 py-4 font-semibold">Cor</th>
                    <th className="px-6 py-4 font-semibold">Status</th>
                    <th className="px-6 py-4 font-semibold">Chapa</th>
                    <th className="px-6 py-4 font-semibold text-right">Ações</th>
                  </tr>
                </thead>
                <tbody className="divide-y divide-slate-700">
                  {pistoes.map((item) => (
                    <tr key={item.id} className="hover:bg-slate-800/40 transition-colors">
                      <td className="px-6 py-4 text-sm font-medium text-white">{item.descricao}</td>
                      <td className="px-6 py-4">
                        <span className={`px-2 py-1 rounded text-[10px] font-bold ${item.cor === 'VERDE' ? 'bg-green-500/20 text-green-400 border border-green-500/50' : 'bg-blue-500/20 text-blue-400 border border-blue-500/50'}`}>
                          {item.cor}
                        </span>
                      </td>
                      <td className="px-6 py-4">
                        <div className="flex items-center space-x-2">
                           <div className={`w-2 h-2 rounded-full ${item.status === 'ATIVO' ? 'bg-green-500 animate-pulse' : 'bg-red-500'}`}></div>
                           <span className="text-sm text-slate-400">{item.status}</span>
                        </div>
                      </td>
                      <td className="px-6 py-4 text-sm text-slate-500 font-mono tracking-tighter">{item.chapa}</td>
                      <td className="px-6 py-4 text-right">
                        <div className="flex justify-end space-x-2">
                          <button className="p-1.5 hover:bg-slate-700 rounded text-slate-400 hover:text-white">
                            <Edit2 size={16} />
                          </button>
                          <button className="p-1.5 hover:bg-slate-700 rounded text-slate-400 hover:text-red-400">
                            <Trash2 size={16} />
                          </button>
                        </div>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        )}

        {activeTab === 'historico' && (
          <div className="space-y-6 animate-in fade-in duration-500">
            <header>
              <h2 className="text-2xl font-bold text-white">Log de Histórico</h2>
              <p className="text-slate-400">Rastreabilidade completa de todas as ações de movimentação</p>
            </header>

            <div className="bg-[#1e293b] rounded-xl border border-slate-700 shadow-xl overflow-hidden">
              {movimentacoes.length === 0 ? (
                <div className="flex flex-col items-center justify-center h-[400px] text-slate-500">
                  <History size={48} className="mb-4 opacity-20" />
                  <p className="text-sm">A aguardar primeiras movimentações do turno...</p>
                </div>
              ) : (
                <table className="w-full text-left">
                  <thead className="bg-slate-800/30 text-slate-400 text-xs uppercase tracking-wider">
                    <tr>
                      <th className="px-6 py-4">Carimbo de Data/Hora</th>
                      <th className="px-6 py-4">Operação</th>
                      <th className="px-6 py-4">Item</th>
                      <th className="px-6 py-4">Destino</th>
                      <th className="px-6 py-4 text-center">Quantidade</th>
                    </tr>
                  </thead>
                  <tbody className="divide-y divide-slate-700">
                    {movimentacoes.map((mov) => (
                      <tr key={mov.id} className="hover:bg-slate-800/40 transition-colors">
                        <td className="px-6 py-4 text-xs font-mono text-slate-400">{mov.data}</td>
                        <td className="px-6 py-4">
                          <span className="text-blue-400 font-bold text-xs uppercase">{mov.fluxo}</span>
                        </td>
                        <td className="px-6 py-4 text-sm text-white font-medium">{mov.componente}</td>
                        <td className="px-6 py-4 text-sm text-slate-300">
                           <span className="bg-slate-700 px-2 py-0.5 rounded text-[10px]">{mov.setor}</span>
                        </td>
                        <td className="px-6 py-4 text-sm text-center text-white font-bold">{mov.quantidade}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              )}
            </div>
          </div>
        )}

      </main>
    </div>
  );
}
